    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@alova/wormhole": "^1.4.5",
    "@antfu/eslint-config": "^2.27.3",
    "@commitlint/cli": "^20.1.0",
